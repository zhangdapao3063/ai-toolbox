# =============================================
# Dify API 配置
# =============================================
# Dify 平台的 API Base URL（部署 Dify 后填入）
# 示例: https://api.dify.ai/v1 或自托管地址
NEXT_PUBLIC_DIFY_API_URL=https://api.dify.ai/v1

# Dify API Key（在 Dify 后台 - 设置 - API Key 中获取）
DIFY_API_KEY=app-xxxxxxxxxxxxxxxxxxxxxxxx

# =============================================
# 可选：自定义域名 / 反向代理地址
# =============================================
# 如果你通过 Nginx/Caddy 等反向代理 Dify，填入代理地址
# NEXT_PUBLIC_API_BASE=https://your-proxy.com/v1
